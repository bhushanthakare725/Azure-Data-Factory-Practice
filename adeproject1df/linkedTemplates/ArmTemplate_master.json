{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adeproject1df"
		},
		"AzureDataLakeStorageLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorageLS'"
		},
		"AzureSqlDBNewLS_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDBNewLS'"
		},
		"AzureSqlDatabaseLS_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabaseLS'"
		},
		"teststorage1accountLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'teststorage1accountLS'"
		},
		"AzureDataLakeStorageLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adeprojectstorage.dfs.core.windows.net/"
		},
		"AzureSqlDBNewLS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adeprojectdbserver.database.windows.net"
		},
		"AzureSqlDBNewLS_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "AdventureWorksLT2025"
		},
		"AzureSqlDBNewLS_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azuredbuser"
		},
		"AzureSqlDatabaseLS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adeprojectdbserver.database.windows.net"
		},
		"AzureSqlDatabaseLS_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adeprojectazuresqldb"
		},
		"AzureSqlDatabaseLS_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azuredbuser"
		},
		"teststorage1accountLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://teststorage1acc.dfs.core.windows.net/"
		},
		"storagetrigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/f38e8667-257b-4692-bef0-014babf0a087/resourceGroups/adeprojects/providers/Microsoft.Storage/storageAccounts/teststorage1acc"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adeproject1df_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorageLS_accountKey": {
						"value": "[parameters('AzureDataLakeStorageLS_accountKey')]"
					},
					"AzureSqlDBNewLS_password": {
						"value": "[parameters('AzureSqlDBNewLS_password')]"
					},
					"AzureSqlDatabaseLS_password": {
						"value": "[parameters('AzureSqlDatabaseLS_password')]"
					},
					"teststorage1accountLS_accountKey": {
						"value": "[parameters('teststorage1accountLS_accountKey')]"
					},
					"AzureDataLakeStorageLS_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorageLS_properties_typeProperties_url')]"
					},
					"AzureSqlDBNewLS_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDBNewLS_properties_typeProperties_server')]"
					},
					"AzureSqlDBNewLS_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDBNewLS_properties_typeProperties_database')]"
					},
					"AzureSqlDBNewLS_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDBNewLS_properties_typeProperties_userName')]"
					},
					"AzureSqlDatabaseLS_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabaseLS_properties_typeProperties_server')]"
					},
					"AzureSqlDatabaseLS_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabaseLS_properties_typeProperties_database')]"
					},
					"AzureSqlDatabaseLS_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabaseLS_properties_typeProperties_userName')]"
					},
					"teststorage1accountLS_properties_typeProperties_url": {
						"value": "[parameters('teststorage1accountLS_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adeproject1df_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adeproject1df_ArmTemplate_0')]"
			]
		},
		{
			"name": "adeproject1df_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"storagetrigger_properties_typeProperties_scope": {
						"value": "[parameters('storagetrigger_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adeproject1df_ArmTemplate_1')]"
			]
		}
	]
}